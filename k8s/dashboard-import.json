{
  "title": "Questionario Online - Kubernetes",
  "tags": ["kubernetes"],
  "timezone": "browser",
  "schemaVersion": 30,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "CPU por Pod (%)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"questionario\",container!=\"\"}[5m])) by (pod) * 100",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": {"mode": "palette-classic"}
        }
      }
    },
    {
      "id": 2,
      "title": "Memoria por Pod (MB)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "sum(container_memory_usage_bytes{namespace=\"questionario\",container!=\"\"}) by (pod) / 1024 / 1024",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "color": {"mode": "palette-classic"}
        }
      }
    },
    {
      "id": 3,
      "title": "Replicas do Backend",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": {"x": 0, "y": 8, "w": 6, "h": 4},
      "targets": [
        {
          "expr": "count(kube_pod_info{namespace=\"questionario\",pod=~\"backend.*\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "red"},
              {"value": 4, "color": "green"}
            ]
          },
          "color": {"mode": "thresholds"}
        }
      },
      "options": {
        "colorMode": "background",
        "textMode": "auto"
      }
    },
    {
      "id": 4,
      "title": "Pods Rodando",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": {"x": 6, "y": 8, "w": 6, "h": 4},
      "targets": [
        {
          "expr": "count(kube_pod_status_phase{namespace=\"questionario\",phase=\"Running\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "red"},
              {"value": 1, "color": "green"}
            ]
          },
          "color": {"mode": "thresholds"}
        }
      },
      "options": {
        "colorMode": "background",
        "textMode": "auto"
      }
    }
  ]
}
