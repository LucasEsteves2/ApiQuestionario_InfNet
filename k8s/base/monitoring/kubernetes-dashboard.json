        "w": 24,
        "h": 8
      },
      "targets": [
        {
          "expr": "kube_pod_info{namespace=\"questionario\",pod=~\"backend.*\"}",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "showHeader": true
