{
  "title": "Questionario - Visao Geral do Kubernetes",
  "uid": "questionario-k8s",
  "tags": [ "kubernetes", "questionario" ],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "Backend Ativo",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "count(kube_pod_status_phase{namespace=\"questionario\",phase=\"Running\",pod=~\"backend.*\"} == 1)",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "background",
        "textMode": "auto",
        "reduceOptions": { "calcs": [ "lastNotNull" ] }
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "green",
                "value": 2
              }
            ]
          }
        }
      }
    },
