    {
      "id": 11,
      "title": "Pods por Sistema",
      "type": "piechart",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "expr": "count(kube_pod_status_phase{namespace=\"questionario\",phase=\"Running\",pod=~\"backend.*\"} == 1)",
          "legendFormat": "Backend",
          "refId": "A"
        },
        {
          "expr": "count(kube_pod_status_phase{namespace=\"questionario\",phase=\"Running\",pod=~\"frontend.*\"} == 1)",
          "legendFormat": "Frontend",
          "refId": "B"
        },
        {
          "expr": "count(kube_pod_status_phase{namespace=\"questionario\",phase=\"Running\",pod=~\"mongodb.*\"} == 1)",
          "legendFormat": "MongoDB",
          "refId": "C"
        },
        {
          "expr": "count(kube_pod_status_phase{namespace=\"questionario\",phase=\"Running\",pod=~\"rabbitmq.*\"} == 1)",
          "legendFormat": "RabbitMQ",
          "refId": "D"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "right"
        },
        "pieType": "donut",
        "tooltip": {
          "mode": "single"
        }
      }
    },
    {
      "id": 12,
      "title": "Pods por Status",
      "type": "piechart",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 8,
        "y": 8,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (phase) (kube_pod_status_phase{namespace=\"questionario\"} == 1)",
          "legendFormat": "{{phase}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "right"
        },
        "pieType": "donut",
        "tooltip": {
          "mode": "single"
        }
      }
    },
    {
      "id": 13,
      "title": "Restart por Pod",
      "type": "bargauge",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 16,
        "y": 8,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum(kube_pod_container_status_restarts_total{namespace=\"questionario\"}) by (pod)",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": [ "lastNotNull" ] }
      }
    },
    {
      "id": 14,
      "title": "CPU por Pod",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"questionario\",container!=\"\",container!=\"POD\"}[5m])) by (pod)",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cores"
        }
      }
    },
